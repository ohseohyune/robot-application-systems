<mujoco model="2dof_arm">
  <compiler angle="radian" autolimits="true"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>


  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    <body name="base" pos="0 0 0">
      <geom type="cylinder" size="0.1 0.05" rgba="0.5 0.5 0.5 1"/>
      
      <body name="link1" pos="0 0 0.05">
        <inertial mass="1.0" pos="0 0 0.5" diaginertia="0.1 0.1 0.01"/>
        <joint name="joint1" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
        <geom type="capsule" size="0.05 0.5" pos="0 0 0.5" rgba="0.8 0.2 0.2 1"/>
        
        <body name="link2" pos="0 0 1">
          <inertial mass="1.0" pos="0 0 0.5" diaginertia="0.1 0.1 0.01"/>
          <joint name="joint2" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
          <geom type="capsule" size="0.05 0.5" pos="0 0 0.5" rgba="0.2 0.8 0.2 1"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="tau1" joint="joint1" gear="1"/>
    <motor name="tau2" joint="joint2" gear="1"/>
  </actuator>
</mujoco>